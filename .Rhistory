library(shiny)
library(igraph)
# --- 2. USER INTERFACE ---
ui <- fluidPage(
title = "GNPS2 to SNAP-MS Bridge",
tags$head(
tags$link(rel = "icon", href = "data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🕸️</text></svg>")
),
div(
style = "display: flex; align-items: center; padding: 10px 0px;",
img(src = "logo_L125.png", height = "200px", style = "margin-right: 20px;"),
h2("GNPS2 to SNAP-MS Bridge", style = "font-size: 60px; font-weight: bold; margin: 0;")
),
hr(),
sidebarLayout(
sidebarPanel(
h4("1. Upload Data"),
fileInput("graphml_file", "Load GNPS2 '.graphml' file", accept = c(".graphml", "application/xml", "text/xml")),
hr(),
h4("2. Download"),
helpText("Once processed, download the fixed graphml file for SNAP-MS."),
downloadButton("dl_graphml", "Download Fixed GraphML", class = "btn-primary"),
hr(style="margin-top: 30px;"),
h5("About & Contact"),
p("This tool acts as a bridge between GNPS2 output and SNAP-MS."),
a(href = "mailto:f9.alan@gmail.com", "Report a bug")
),
mainPanel(
tabsetPanel(
tabPanel("Summary",
h4("Welcome to the GNPS2 to SNAP-MS Bridge"),
p("This app modifies a GNPS2 graphml file by mapping its attributes to the GNPS1 format required by SNAP-MS."),
hr(),
h5("Graph Processing Status:"),
verbatimTextOutput("graph_summary")
)
)
)
)
)
# --- 3. SERVER LOGIC ---
server <- function(input, output, session) {
options(shiny.maxRequestSize = 500*1024^2) # Allows large graphml files
processed_graph <- reactive({
req(input$graphml_file)
tryCatch({
# Read graph
gnps2 <- read_graph(input$graphml_file$datapath, format = "graphml")
# 1. Map GNPS2 columns (Source) to GNPS1 columns (Target)
if ("id" %in% vertex_attr_names(gnps2)) {
V(gnps2)$`cluster index` <- V(gnps2)$id
}
# B. Handle Mass and Retention Time
if ("mz" %in% vertex_attr_names(gnps2)) {
V(gnps2)$`parent mass` <- V(gnps2)$mz
V(gnps2)$`precursor mass` <- V(gnps2)$mz
} else {
stop("Error: 'mz' attribute not found in GNPS2 file. Cannot create mass columns.")
}
if ("rt" %in% vertex_attr_names(gnps2)) {
V(gnps2)$RTMean <- V(gnps2)$rt
V(gnps2)$RTConsensus <- V(gnps2)$rt
}
# C. Handle Library Matches
if (!"library_compound_name" %in% vertex_attr_names(gnps2)) {
V(gnps2)$Compound_Name <- "N/A"
} else {
V(gnps2)$Compound_Name <- ifelse(is.na(V(gnps2)$library_compound_name) | V(gnps2)$library_compound_name == "",
"N/A",
V(gnps2)$library_compound_name)
}
if ("library_SMILES" %in% vertex_attr_names(gnps2)) V(gnps2)$Smiles <- V(gnps2)$library_SMILES
if ("library_InChI" %in% vertex_attr_names(gnps2)) V(gnps2)$INCHI <- V(gnps2)$library_InChI
# D. Add Missing "Cosmetic" Attributes
V(gnps2)$`sum(precursor intensity)` <- 100.0
V(gnps2)$NODE_TYPE <- "Feature Node"
# --- 3. Fix Edge Attributes ---
if ("score" %in% edge_attr_names(gnps2)) {
E(gnps2)$cosine_score <- E(gnps2)$score
E(gnps2)$EdgeScore <- E(gnps2)$score
}
if ("deltamz" %in% edge_attr_names(gnps2)) {
E(gnps2)$mass_difference <- E(gnps2)$deltamz
}
# --- 4. Recalculate Components (Clusters) ---
curr_components <- components(gnps2)
V(gnps2)$componentindex <- curr_components$membership
# Handle Singletons
singletons <- which(degree(gnps2) == 0)
if(length(singletons) > 0) {
V(gnps2)$componentindex[singletons] <- -1
}
return(gnps2)
}, error = function(e) {
showNotification(paste("Error processing graph:", e$message), type = "error", duration = 10)
return(NULL)
})
})
output$graph_summary <- renderPrint({
g <- processed_graph()
req(g)
cat("Graph processing successful!\n\n")
cat("Number of nodes:", vcount(g), "\n")
cat("Number of edges:", ecount(g), "\n\n")
cat("Top Component Sizes (Index -1 = Singletons):\n")
print(head(sort(table(V(g)$componentindex), decreasing = TRUE), 10))
})
output$dl_graphml <- downloadHandler(
filename = function() {
"GNPS2_FIXED_for_SNAPMS.graphml"
},
content = function(file) {
req(processed_graph())
write_graph(processed_graph(), file, format = "graphml")
}
)
}
shinyApp(ui, server)
runApp()
runApp()
runApp()
